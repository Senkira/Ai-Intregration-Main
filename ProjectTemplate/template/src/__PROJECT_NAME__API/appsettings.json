{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "MainDb": "Data Source=__PROJECT_NAME__.db"
  },
  "Jwt": {
    "Key": "__PROJECT_NAME__API-Default-Secret-Key-For-Dev-Only!!",
    "Issuer": "__PROJECT_NAME__API",
    "ExpiresInHours": 8
  },
  "ServiceTime": {
    "Start": "00:00",
    "End": "23:59",
    "OutOfServiceMessage": "Service is currently unavailable. Please try again later.",
    "Ignore": [ "HealthCheck/Index" ]
  }
}
